# SedSim Environment Variables
# Copy this file to .env and fill in the values.

# ---- Option A: Cloudflare Worker Proxy (RECOMMENDED for production) ----
# Deploy the worker in /worker, then set the URL here.
# The proxy keeps your Anthropic API key server-side.
VITE_CLAUDE_PROXY_URL=https://sedsim-claude-proxy.<your-subdomain>.workers.dev

# ---- Option B: Direct API Key (development only) ----
# WARNING: This key will be bundled into the client-side JavaScript.
# Only use this for local development, NEVER in production builds.
# VITE_ANTHROPIC_API_KEY=sk-ant-xxxxx
