{
  "id": "colonoscopy_asa1",
  "title": "Routine Colonoscopy - ASA I",
  "description": "Straightforward colonoscopy sedation for a healthy adult ASA I patient. Focus on stepwise titration to MOASS 2-3 with midazolam and fentanyl.",
  "tags": [
    "colonoscopy",
    "ASA I",
    "moderate sedation",
    "easy"
  ],
  "patient": {
    "archetypeId": "healthy_adult"
  },
  "learningObjectives": [
    "Perform focused pre-sedation assessment and assign ASA class",
    "Safely titrate midazolam and fentanyl to MOASS 2-3",
    "Recognise early respiratory depression and intervene appropriately",
    "Monitor vitals and capnography throughout the procedure"
  ],
  "estimatedDurationSec": 480,
