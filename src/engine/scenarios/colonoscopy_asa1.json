      ],
      "scoring": {
        "maxScore": 10,
        "checklistItems": [
          {
            "id": "ci_discharge_moass",
            "description": "Correctly identifies MOASS 3 as minimum discharge threshold",
            "weight": 10,
            "evaluationHint": "Patient selected MOASS 3"
          }
        ]
      }
    },
    {
      "id": "state_debrief_end",
